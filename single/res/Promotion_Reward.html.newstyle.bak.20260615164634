<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>推广收益流水</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    :root {
      --primary: #5b8cff;
      --success: #22a06b;
      --danger: #f44336;
      --bg: #f4f6fb;
      --card: #ffffff;
      --border: #e5e7eb;
      --text: #333;
      --muted: #777;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: "PingFang SC", "Microsoft YaHei", Arial, sans-serif; }
    body { background: var(--bg); color: var(--text); padding: 20px; }
    .page { max-width: 1200px; margin: 0 auto; }
    .title { font-size: 24px; font-weight: 700; margin-bottom: 18px; }
    .card { background: var(--card); border-radius: 12px; padding: 18px; margin-bottom: 18px; box-shadow: 0 4px 20px rgba(0,0,0,.05); }
    .card h3 { font-size: 18px; margin-bottom: 14px; }
    .toolbar { display: flex; gap: 10px; flex-wrap: wrap; align-items: end; }
    .form-item { width: 180px; }
    .form-item label { display: block; font-size: 13px; color: var(--muted); margin-bottom: 6px; }
    input { width: 100%; height: 38px; border: 1px solid var(--border); border-radius: 8px; padding: 0 10px; font-size: 14px; outline: none; background: #fff; }
    input:focus { border-color: var(--primary); }
    button { height: 38px; border: none; border-radius: 8px; padding: 0 14px; cursor: pointer; font-size: 14px; color: #fff; background: var(--primary); }
    button:hover { opacity: .9; }
    .btn-secondary { background: #6b7280; }
    .msg { margin-top: 12px; padding: 10px 12px; border-radius: 8px; display: none; font-size: 14px; line-height: 1.6; }
    .msg.ok { display: block; background: #e9f8f1; color: #137a4b; border: 1px solid #bcebd6; }
    .msg.err { display: block; background: #fff0f0; color: #c62828; border: 1px solid #ffcaca; }
    .summary { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
    .metric { border: 1px solid var(--border); border-radius: 10px; padding: 14px; background: #fff; }
    .metric .k { font-size: 13px; color: var(--muted); margin-bottom: 8px; }
    .metric .v { font-size: 22px; font-weight: 800; color: #111827; }
    .metric.primary .v { color: var(--primary); }
    .metric.success .v { color: var(--success); }
    .subline { margin-top: 10px; color: var(--muted); font-size: 13px; line-height: 1.7; }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 1000px; }
    th, td { border-bottom: 1px solid var(--border); padding: 10px 8px; text-align: left; font-size: 14px; white-space: nowrap; }
    th { background: #f8f9fc; color: #555; font-weight: 600; }
    tbody tr:hover { background: #fbfcff; }
    .amount { color: var(--success); font-weight: 800; }
    .order-id { max-width: 260px; overflow: hidden; text-overflow: ellipsis; display: inline-block; vertical-align: bottom; }
    .state { text-align: center; color: var(--muted); padding: 26px 0; font-size: 14px; }
    .badge { display: inline-block; padding: 3px 8px; border-radius: 999px; font-size: 12px; background: #e9f8f1; color: #137a4b; }
    @media (max-width: 768px) {
      body { padding: 12px; }
      .summary { grid-template-columns: 1fr; }
      .toolbar { display: grid; grid-template-columns: 1fr; }
      .form-item { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="title">推广收益流水</div>

    <div class="card">
      <h3>实时预览</h3>
      <div class="toolbar">
        <div class="form-item">
          <label for="previewDate">预览日期</label>
          <input id="previewDate" type="date">
        </div>
        <button type="button" id="queryBtn">查询</button>
        <button type="button" class="btn-secondary" id="todayBtn">今天</button>
      </div>
      <div id="msg" class="msg"></div>
      <div class="subline" id="accountInfo">当前为实时预估数据，最终收益以系统结算为准。</div>
    </div>

    <div class="card">
      <div class="summary">
        <div class="metric primary">
          <div class="k">预计收入</div>
          <div class="v" id="estimatedReward">0.00 元</div>
        </div>
        <div class="metric">
          <div class="k">有效订单</div>
          <div class="v" id="validOrderCount">0</div>
        </div>
        <div class="metric">
          <div class="k">推广消费金额</div>
          <div class="v" id="validOrderAmount">0.00 元</div>
        </div>
        <div class="metric success">
          <div class="k">奖励比例</div>
          <div class="v" id="rewardRate">0%</div>
        </div>
      </div>
    </div>

    <div class="card">
      <h3>收入明细</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>订单时间</th>
              <th>被邀请人</th>
              <th>场地ID</th>
              <th>支付方式</th>
              <th>消费金额</th>
              <th>比例</th>
              <th>预计收益</th>
              <th>状态</th>
              <th>订单号</th>
            </tr>
          </thead>
          <tbody id="tbody"></tbody>
        </table>
      </div>
      <div id="state" class="state">加载中...</div>
    </div>
  </div>

<script>
const API = '/api/promotion/GetInviteRewardPreview.php';
const els = {
  previewDate: document.getElementById('previewDate'),
  queryBtn: document.getElementById('queryBtn'),
  todayBtn: document.getElementById('todayBtn'),
  msg: document.getElementById('msg'),
  accountInfo: document.getElementById('accountInfo'),
  estimatedReward: document.getElementById('estimatedReward'),
  validOrderCount: document.getElementById('validOrderCount'),
  validOrderAmount: document.getElementById('validOrderAmount'),
  rewardRate: document.getElementById('rewardRate'),
  tbody: document.getElementById('tbody'),
  state: document.getElementById('state')
};

function pad(n){ return String(n).padStart(2, '0'); }
function ymd(d){ const x = new Date(d); return `${x.getFullYear()}-${pad(x.getMonth()+1)}-${pad(x.getDate())}`; }
function money(n){ return `${Number(n || 0).toFixed(2)} 元`; }
function esc(v){ return String(v ?? '').replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s])); }
function showMsg(type, text){ els.msg.className = `msg ${type}`; els.msg.textContent = text; }
function clearMsg(){ els.msg.className = 'msg'; els.msg.textContent = ''; }

function renderRows(rows){
  if (!rows.length) {
    els.tbody.innerHTML = '';
    els.state.textContent = '暂无预计收入明细';
    return;
  }
  els.tbody.innerHTML = rows.map(row => {
    const statusText = row.generated_status ? '已生成' : '预估';
    const nickname = row.invitee_nickname ? ` / ${esc(row.invitee_nickname)}` : '';
    return `
      <tr>
        <td>${esc(row.end_time)}</td>
        <td>${esc(row.invitee_uid)}${nickname}</td>
        <td>${esc(row.venue_id)}</td>
        <td>${esc(row.pays_type)}</td>
        <td>${money(row.order_amount)}</td>
        <td>${Number(row.reward_rate_percent || 0)}%</td>
        <td class="amount">+${money(row.estimated_reward_amount)}</td>
        <td><span class="badge">${statusText}</span></td>
        <td><span class="order-id" title="${esc(row.order_id)}">${esc(row.order_id)}</span></td>
      </tr>`;
  }).join('');
  els.state.textContent = `共 ${rows.length} 条明细`;
}

async function loadPreview(){
  clearMsg();
  const date = els.previewDate.value || ymd(new Date());
  els.state.textContent = '加载中...';
  els.tbody.innerHTML = '';
  try {
    const url = new URL(API, window.location.origin);
    url.searchParams.set('date', date);
    const res = await fetch(url.toString(), { credentials: 'include', headers: { 'Accept': 'application/json' }});
    const json = await res.json();
    if (!json || json.code !== 200) {
      throw new Error((json && json.msg) || '查询失败');
    }
    const data = json.data || {};
    const summary = data.summary || {};
    const rows = data.list || [];
    els.estimatedReward.textContent = money(summary.estimated_reward_amount);
    els.validOrderCount.textContent = String(summary.valid_order_count || 0);
    els.validOrderAmount.textContent = money(summary.valid_order_amount);
    els.rewardRate.textContent = `${Number(summary.reward_rate_percent || 0)}%`;
    els.accountInfo.textContent = `邀请人UID：${data.inviter_uid || '-'}　邀请码：${data.invite_code || '-'}　推广等级：${data.promotion_level || 'DEFAULT'}　规则ID：${data.rule_id || '-'}。当前为实时预估数据，最终收益以系统结算为准。`;
    renderRows(rows);
  } catch (err) {
    showMsg('err', err.message || '网络异常，请刷新重试');
    els.state.textContent = '加载失败';
  }
}

els.queryBtn.addEventListener('click', loadPreview);
els.todayBtn.addEventListener('click', () => { els.previewDate.value = ymd(new Date()); loadPreview(); });
els.previewDate.value = ymd(new Date());
loadPreview();
</script>
</body>
</html>